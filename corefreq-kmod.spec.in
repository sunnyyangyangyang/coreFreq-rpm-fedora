# Filename: corefreq-kmod.spec.in

%if 0%{?fedora}
%global buildforkernels akmod
%endif

%global debug_package %{nil}
%global kmod_name corefreq

Name:          corefreq-kmod
Version:       @COREFREQ_VERSION@
Release:       @RELEASE@
Summary:       CoreFreq kernel module

License:       GPL-2.0-only
URL:           https://github.com/cyring/CoreFreq

Source0:       corefreq-kmod-%{version}.tar.gz

ExclusiveArch: x86_64

# get the needed BuildRequires (in parts depending on what we build for)
%global AkmodsBuildRequires %{_bindir}/kmodtool
BuildRequires: %{AkmodsBuildRequires}
BuildRequires: gcc, make

%{!?kernels:BuildRequires: buildsys-build-rpmfusion-kerneldevpkgs-%{?buildforkernels:%{buildforkernels}}%{!?buildforkernels:current}-%{_target_cpu} }

# kmodtool does its magic here
%{expand:%(kmodtool --target %{_target_cpu} --repo rpmfusion --kmodname %{kmod_name} %{?buildforkernels:--%{buildforkernels}} %{?kernels:--for-kernels "%{?kernels}"} 2>/dev/null) }

%description
The CoreFreq %{version} kernel module for kernel %{kversion}.
CoreFreq is a CPU monitoring software designed for 64-bit processors.

%prep
# error out if there was something wrong with kmodtool
%{?kmodtool_check}

# print kmodtool output for debugging purposes:
kmodtool --target %{_target_cpu} --repo rpmfusion --kmodname %{kmod_name} %{?buildforkernels:--%{buildforkernels}} %{?kernels:--for-kernels "%{?kernels}"} 2>/dev/null

%setup -q -c -T -a 0

for kernel_version in %{?kernel_versions} ; do
    cp -a corefreq-kmod-%{version} _kmod_build_${kernel_version%%___*}
done

%build
for kernel_version in %{?kernel_versions}; do
    pushd _kmod_build_${kernel_version%%___*}/
    %make_build \
        KVER="${kernel_version%%___*}" \
        KDIR="${kernel_version##*___}" \
        modules
    popd
done

%install
for kernel_version in %{?kernel_versions}; do
    mkdir -p $RPM_BUILD_ROOT/%{kmodinstdir_prefix}/${kernel_version%%___*}/%{kmodinstdir_postfix}/
    install -D -m 0644 _kmod_build_${kernel_version%%___*}/build/corefreqk.ko \
         $RPM_BUILD_ROOT/%{kmodinstdir_prefix}/${kernel_version%%___*}/%{kmodinstdir_postfix}/
done
%{?akmod_install}

%changelog
* Sat Sep 07 2025 Package Maintainer <package@example.com> - @COREFREQ_VERSION@-@RELEASE@
- Follow nvidia-kmod pattern for reliable kernel module building