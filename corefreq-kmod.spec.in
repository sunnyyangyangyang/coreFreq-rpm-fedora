# Filename: corefreq-kmod.spec.in

# Disable debug packages
%global _debugsource_packages 0
%global _debuginfo_packages 0
%global debug_package %{nil}

%global kmod_name corefreq

Name:          %{kmod_name}-kmod
Version:       @COREFREQ_VERSION@
Release:       @RELEASE@
Summary:       The %{kmod_name} kernel module (corefreqk)

License:       GPL-2.0-only
URL:           https://github.com/cyring/CoreFreq

Source0:       %{kmod_name}-kmod-%{version}.tar.gz

BuildRequires: gcc make
BuildRequires: kernel-devel

# This line defines the %{kversion} macro for us.
%{expand:%(kmodtool --target %{_target_cpu} --kmodname %{kmod_name} 2>/dev/null)}

%description
This package provides the %{kmod_name} kernel module (corefreqk.ko) for CoreFreq,
built by the akmods system for the currently running kernel.

%prep
%autosetup -n %{kmod_name}-kmod-%{version}

%build
# The %build section works correctly with %{kversion}
make modules KVER=%{kversion}

%install
# The %install section is a shell script, so macros are expanded correctly here.
# 1. Create the correct directory using the expanded macro.
install -d %{buildroot}/lib/modules/%{kversion}/extra/%{kmod_name}/

# 2. Install the kernel module into the correct directory.
install -m 0644 build/corefreqk.ko %{buildroot}/lib/modules/%{kversion}/extra/%{kmod_name}/

# === THE DEFINITIVE FIX ===
# 3. Since the %files section fails to expand the macro, we write the
#    correct, fully-expanded file path into a manifest file.
#    This file will be read by the %files section later.
echo "/lib/modules/%{kversion}/extra/%{kmod_name}/corefreqk.ko" > kmod-file-list.txt

%files -f kmod-file-list.txt
# === THE DEFINITIVE FIX ===
# The -f flag tells RPM to read the list of files from the manifest file
# we created in the %install section. This completely bypasses the macro
# expansion problem in the %files section itself.
# We leave this section empty except for the line above.

%clean
rm -rf %{buildroot}

%changelog
* Sun Sep 08 2025 Package Maintainer <package@example.com> - @COREFREQ_VERSION@-@RELEASE@
- Final fix: Use a manifest file generated in %install to bypass macro expansion issues in %files.